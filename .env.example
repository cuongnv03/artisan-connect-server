# Server
PORT=5000
NODE_ENV=development
API_PREFIX=/api

# Database - update with your PostgreSQL connection string
DATABASE_URL="postgresql://postgres:1234@localhost:5432/artisan_connect?schema=public"

# JWT - change these in production
JWT_ACCESS_SECRET=dev-access-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_ACCESS_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# Cookie
COOKIE_SECRET=dev-cookie-secret-change-in-production

# CORS
CORS_ORIGIN=http://localhost:3000
CLIENT_URL=http://localhost:3000

# Cloudinary - optional, file uploads disabled without this
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email - optional, email features disabled without this
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=Artisan Connect
EMAIL_FROM_ADDRESS=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif
